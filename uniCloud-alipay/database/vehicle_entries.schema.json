{
  "bsonType": "object",
  "required": ["userid", "record_date", "plate", "name", "phone", "id_card", "created_at"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "userid": {
      "bsonType": "string",
      "title": "企业微信用户 ID"
    },
    "record_date": {
      "bsonType": "string",
      "title": "记录日期",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "plate": {
      "bsonType": "string",
      "title": "车牌号"
    },
    "name": {
      "bsonType": "string",
      "title": "司机姓名"
    },
    "phone": {
      "bsonType": "string",
      "title": "随车电话",
      "pattern": "^\\d{11}$"
    },
    "id_card": {
      "bsonType": "string",
      "title": "身份证号",
      "pattern": "^[\\dX]{18}$"
    },
    "created_at": {
      "bsonType": "number",
      "title": "创建时间"
    }
  },
  "index": [
    {
      "IndexName": "idx_user_date",
      "MgoKeySchema": {
        "MgoIndexKeys": [
          {
            "Name": "userid",
            "Direction": "1"
          },
          {
            "Name": "record_date",
            "Direction": "1"
          },
          {
            "Name": "created_at",
            "Direction": "1"
          }
        ],
        "MgoIsUnique": false
      }
    }
  ]
}
